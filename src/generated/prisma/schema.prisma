// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Tender {
  id       String   @id @default(cuid())
  title    String
  ministry String
  budget   Float
  deadline DateTime
  status   String
  category String
}

model Vendor {
  id            String @id @default(cuid())
  name          String
  totalWon      Float
  winRate       Float
  totalAwards   Int
  localContent  Float
  topMinistries String
}

model Award {
  id        String   @id @default(cuid())
  title     String
  vendorId  String
  ministry  String
  amount    Float
  startDate DateTime
}

model Project {
  id                String @id @default(cuid())
  name              String
  totalBudget       Float
  spentToDate       Float
  activeSubProjects Int
  progressPercent   Float
}

model GlobalStat {
  id              String @id @default(cuid())
  activeTenders   Int
  totalAwardValue Float
  activeVendors   Int
}
